# Normaliza line-endings a LF en el repo y en el checkout (evita volteos CRLF<->LF
# en el repo compartido entre sesiones Windows). Sin esto, un checkout en Windows
# con autocrlf reescribia index.js entero y ensuciaba los merges.
* text=auto eol=lf

*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binarios: nunca tocar
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.pdf  binary
*.mp4  binary
*.mp3  binary
*.ico  binary
